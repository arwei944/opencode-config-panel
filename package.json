{
  "name": "opencode-config-panel",
  "version": "1.0.0",
  "private": true,
  "description": "opencode 可视化配置面板",
  "type": "module",
  "bin": {
    "occ": "./scripts/occ.mjs"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "tsx watch server/index.ts",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "cli": "tsx scripts/occ.ts",
    "occ": "tsx scripts/occ.ts",
    "start": "tsx server/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:cli": "node scripts/test-cli.mjs",
    "test:all": "npm run test && npm run test:cli",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"server/**/*.ts\" \"core/**/*.ts\" \"cli/**/*.ts\" \"shared/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"server/**/*.ts\" \"core/**/*.ts\" \"cli/**/*.ts\" \"shared/**/*.ts\" \"tests/**/*.ts\"",
    "clean": "rm -rf dist coverage",
    "validate": "npm run lint && npm run test:all && npm run build"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "js-yaml": "^4.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.26.0",
    "rehype-highlight": "^7.0.0",
    "remark-gfm": "^4.0.0",
    "tsx": "^4.16.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
